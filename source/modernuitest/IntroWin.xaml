<Window x:Class="modernuitest.IntroWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:modernuitest"
        mc:Ignorable="d"
        Title="IntroWin" Height="500" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        >

    <Border Background="#00224B" CornerRadius="25" BorderThickness="3" BorderBrush="Black">
        <Border Background="#001B3A" Margin="15" BorderBrush="SkyBlue" BorderThickness="4" CornerRadius="18">
    <StackPanel Background="Transparent" >
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CloseBtn" Content="X" Width="40" Height="30" 
                            Click="CloseBtn_Click"
                            Background="Transparent" BorderThickness="0" FontSize="16" Foreground="White"
                            ToolTip="Close"
                            FontWeight="Bold"
                            Padding="5"/>
                </StackPanel>
                <DockPanel>
                   <Image x:Name="ProductIMG" Height="340" Width="450" Source="/newFolder/serial.png"/>
                </DockPanel>
        
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
           <Button x:Name="Prv" Content="&lt;" Foreground="White" FontWeight="ExtraBold" Click="Prv_Click"/>
           <ComboBox HorizontalAlignment="Center" x:Name="Product" SelectedIndex="0" SelectionChanged="Product_SelectionChanged">
                <ComboBoxItem Content="Delta Robot" />
                <ComboBoxItem Content="4DoF Serial Manipulator"/>
            </ComboBox>
            <Button x:Name="Nxt" Content=">" Foreground="White" FontWeight="ExtraBold" Click="Nxt_Click"/>
        </StackPanel>
        
        <Button x:Name="OpenBtn" Content="Open"  BorderBrush="Black" Foreground="White" BorderThickness="2" VerticalAlignment="Center" HorizontalAlignment="Center" Click="OpenBtn_Click" Padding="30,5,30,5" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Border>
</Window>
